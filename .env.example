# =====================================================
# zapEngine Monorepo - Environment Configuration
# =====================================================
#
# Copy to .env and fill in values. Sections are organised by owning app.
# Each line is tagged:
#   [Required]   — app refuses to start / tests fail without it
#   [Optional]   — falls back to a safe default, or the feature is gated off
#   [Default: X] — used when the var is unset
#
# ---- Quick start ------------------------------------
# Minimal vars to run frontend dev (UI only, no chain):
#   VITE_ACCOUNT_API_URL, VITE_ANALYTICS_ENGINE_URL
# Minimal vars to run account-engine locally:
#   SUPABASE_URL, SUPABASE_ANON_KEY, ALPHA_ETL_URL, ALPHA_ETL_WEBHOOK_SECRET
# Minimal vars to run analytics-engine tests:
#   DATABASE_READ_ONLY_URL (Supabase read-only replica — request from team)
# Minimal vars to run podcast-pipeline ingest:
#   OPENROUTER_API_KEY, R2_* (5 vars), SUPABASE_URL,
#   SUPABASE_SERVICE_ROLE_KEY, GOOGLE_APPLICATION_CREDENTIALS_BASE64
# -----------------------------------------------------

# ============================================
# region: shared (used across multiple apps)
# ============================================

NODE_ENV=development                                   # [Default: development]

# Supabase — used by account-engine, podcast-pipeline.
# Provision a project at https://supabase.com.
SUPABASE_URL=https://your-project-ref.supabase.co       # [Required]
SUPABASE_ANON_KEY=your-anon-key-here                    # [Required] RLS-bound client key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here    # [Required for admin/server flows] never expose client-side

# ============================================
# region: account-engine (port 3004)
# ============================================

# Alpha-ETL integration (wallet data fetch webhooks)
ALPHA_ETL_URL=http://localhost:3003                     # [Required] alpha-etl base URL
ALPHA_ETL_WEBHOOK_SECRET=your-secure-webhook-secret     # [Required] must match alpha-etl's WEBHOOK_SECRET
ALPHA_ETL_DATABASE_URL=                                 # [Optional] direct Postgres URL when account-engine writes ETL events

# Server
ACCOUNT_ENGINE_PORT=3004                                # [Default: 3004]

# Email (weekly portfolio reports)
EMAIL_USER=your-gmail-address@gmail.com                 # [Optional] disables reports if missing
EMAIL_APP_PASSWORD=your-gmail-app-password              # [Optional] Gmail App Password (not regular password)

# Admin notifications gate
ADMIN_NOTIFICATIONS_ENABLED=true                        # [Default: true] gate for Telegram failure alerts

# Analytics Engine integration
ANALYTICS_ENGINE_URL=http://127.0.0.1:8001              # [Required] analytics-engine base URL

# LI.FI / Base deposit orchestration
LIFI_INTEGRATOR=zap-pilot                               # [Default: zap-pilot]
LIFI_API_KEY=                                           # [Optional] free tier works without
RPC_URL_BASE=https://mainnet.base.org                   # [Default: public RPC]
RPC_URL_ETHEREUM=https://ethereum-rpc.publicnode.com    # [Default: public RPC]
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc           # [Default: public RPC]

# API Key Authentication
ADMIN_API_KEY=your-secret-api-key-here                  # [Required for admin endpoints]

# Telegram Bot — portfolio drift alerts.
# Distinct from podcast-pipeline's PIPELINE_TELEGRAM_* (separate bot, separate var prefix).
# Create via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token              # [Optional] disables drift alerts if missing
TELEGRAM_BOT_NAME=YourBotName                           # [Optional]
TELEGRAM_WEBHOOK_SECRET=your-secure-webhook-secret      # [Required if TELEGRAM_BOT_TOKEN is set]

# ============================================
# region: alpha-etl (port 3003)
# ============================================

# Database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres  # [Required] Supabase Postgres

# Server
ALPHA_ETL_PORT=3003                                     # [Default: 3003]
HOST=127.0.0.1                                          # [Default: 127.0.0.1] bind interface

# Webhook auth — must match account-engine's ALPHA_ETL_WEBHOOK_SECRET above
WEBHOOK_SECRET=your-pipedream-webhook-secret            # [Required]

# External APIs
DEBANK_API_URL=https://pro-openapi.debank.com           # [Default: pro endpoint]
DEBANK_API_KEY=your-debank-api-key-optional             # [Optional] required for production-scale queries
DEBANK_STRICT_ERRORS=true                               # [Default: true] fail fast on DeBank errors
HYPERLIQUID_API_URL=https://api-ui.hyperliquid.xyz      # [Default]
HYPERLIQUID_RATE_LIMIT_RPM=60                           # [Default: 60]
COINGECKO_API_URL=https://api.coingecko.com/api/v3      # [Default]

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60                       # [Default: 60]
RATE_LIMIT_BURST=10                                     # [Default: 10]

# Logging
LOG_LEVEL=info                                          # [Default: info] info|debug|warn|error

# Materialized View refresh — required for immediate post-ETL visibility
ENABLE_MV_REFRESH=true                                  # [Default: true]
MOCK_APIS=false                                         # [Default: false] true bypasses external APIs in dev

# CoinMarketCap (Fear & Greed Index pipeline)
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key        # [Required for FGI pipeline]
COINMARKETCAP_API_URL=https://pro-api.coinmarketcap.com # [Default]

# Alpha Vantage (S&P500 stock-price pipeline) — free tier: 5 req/min, 25 req/day
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alphavantage-api-key         # [Required for stock-price pipeline]

# ============================================
# region: analytics-engine (port 8001)
# ============================================

# Environment
ENVIRONMENT=development                                 # [Default: development]
DEBUG=true                                              # [Default: true in dev]

# Server
ANALYTICS_ENGINE_PORT=8001                              # [Default: 8001]

# Database — READ-ONLY connection enforced at app level
DATABASE_READ_ONLY=true                                 # [Default: true] DO NOT change — analytics-engine has no write code
# Supabase read-only replica URL. Required for `pnpm verify:analytics-engine` and the
# in-process snapshot gate triggered by `pnpm test:ci`.
# Local pg containers WILL NOT WORK — they lack production alpha_raw.* series.
DATABASE_READ_ONLY_URL=postgresql+psycopg://readonly_user:readonly_password@aws-0-region.pooler.supabase.co:5432/postgres  # [Required for tests]

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8000  # [Default: localhost dev ports]

# ============================================
# region: landing-page (Next.js, port 3000)
# ============================================

NEXT_PUBLIC_APP_URL=https://app.zap-pilot.org           # [Default: prod URL]
NEXT_PUBLIC_ANALYTICS_API_URL=http://localhost:8001     # [Required] analytics-engine base URL

# Analytics — leave empty to disable in dev
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX                          # [Optional]
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here     # [Optional]
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id_here               # [Optional]

# ============================================
# region: frontend (Vite, port 3000)
# ============================================

VITE_ACCOUNT_API_URL=http://127.0.0.1:3004              # [Required] account-engine base URL
VITE_ANALYTICS_ENGINE_URL=http://localhost:8001         # [Required] analytics-engine base URL

# Dev overlays (memory cost — keep off unless debugging)
VITE_ENABLE_RQ_DEVTOOLS=1                               # [Default: 1 in dev]
VITE_ENABLE_LOG_VIEWER=0                                # [Default: 0]

# Logging
VITE_ENABLE_DEBUG_LOGGING=false                         # [Default: false] enable debug logs in prod
VITE_ENABLE_DEV_LOGGING=true                            # [Default: true]

# ============================================
# region: podcast-pipeline (from-fed-to-chain)
# ============================================
# Uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY from the shared section above.

# LLM (OpenRouter — Anthropic / OpenAI compatible)
OPENROUTER_API_KEY=your-openrouter-api-key              # [Required]
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1        # [Default]
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022          # [Default]
LLM_THINKING_MODEL=                                     # [Optional] separate model for reasoning steps

# Google Cloud Text-to-Speech — provide ONE form.
# Fly deployment requires the base64 form (file paths aren't portable).
GOOGLE_APPLICATION_CREDENTIALS_BASE64=                  # [Required (or _CREDENTIALS path)]
GOOGLE_APPLICATION_CREDENTIALS=                         # [Optional] path to service account JSON (local dev)
FISH_AUDIO_API_KEY=                                     # [Optional] fallback TTS provider

# Cloudflare R2 (S3-compatible) — HLS segment storage
R2_ENDPOINT=                                            # [Required]
R2_ACCESS_KEY_ID=                                       # [Required]
R2_SECRET_ACCESS_KEY=                                   # [Required]
R2_BUCKET_NAME=                                         # [Required]
R2_PUBLIC_BASE_URL=                                     # [Required] public CDN base URL for HLS manifest

# Telegram trigger bot (separate bot from account-engine TELEGRAM_*).
# Leave empty to disable the webhook route.
PIPELINE_TELEGRAM_BOT_TOKEN=                            # [Optional]
PIPELINE_TELEGRAM_WEBHOOK_SECRET=                       # [Required if PIPELINE_TELEGRAM_BOT_TOKEN is set]
PIPELINE_TELEGRAM_ALLOWED_USER_IDS=                     # [Optional] CSV; empty = all users allowed

# Bearer token for /ingest admin endpoint
INGEST_ADMIN_TOKEN=                                     # [Required for admin trigger]

# Override default prompt path
SCRIPT_PROMPT_PATH=                                     # [Default: ./prompts/script-system-prompt.txt]

# Supabase schema for podcast-pipeline data
SUPABASE_DB_SCHEMA=from_fed_to_chain                    # [Required] must equal "from_fed_to_chain"
