# ============================================
# ZapEngine Monorepo - Unified Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values.
# Each section corresponds to a specific app in the monorepo.
# ============================================

# ============================================
# Global / Shared Configuration
# ============================================
NODE_ENV=development

# ============================================
# account-engine (port 3004)
# ============================================

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alpha-ETL Configuration (for wallet data fetch webhooks)
ALPHA_ETL_URL=http://localhost:3003
ALPHA_ETL_WEBHOOK_SECRET=your-secure-webhook-secret
ALPHA_ETL_DATABASE_URL=

# Server Configuration (port 3004)
ACCOUNT_ENGINE_PORT=3004

# Email Configuration (for weekly reports)
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# Admin Notification Configuration (for job failure alerts)
ADMIN_NOTIFICATIONS_ENABLED=true

# Analytics Engine Configuration
ANALYTICS_ENGINE_URL=http://127.0.0.1:8001

# LI.FI / Base deposit orchestration
LIFI_INTEGRATOR=zap-pilot
LIFI_API_KEY=
# Default invest allocation as JSON ({"<chainId>": weight}). Rollout lever for
# cross-chain deposits: keep {"8453":1} until LI.FI HyperCore (1337) routes are
# verified, then e.g. {"8453":0.7,"1337":0.3}. No deploy needed to change.
DEPOSIT_DEFAULT_SPLIT={"8453":1}
# Hyperliquid network for HLP deposit follow-ups (mainnet | testnet).
# Not the same as alpha-etl's HYPERLIQUID_API_URL (info-only mirror).
HYPERLIQUID_NETWORK=mainnet
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_ETHEREUM=https://ethereum-rpc.publicnode.com
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc

# Privy Wallets API (server-only; never expose PRIVY_APP_SECRET to Vite)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# API Key Authentication
ADMIN_API_KEY=your-secret-api-key-here

# Telegram Bot Configuration (for portfolio drift alerts)
# Create a bot via @BotFather on Telegram to get these values
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_NAME=YourBotName
TELEGRAM_WEBHOOK_SECRET=your-secure-webhook-secret

# ============================================
# alpha-etl (port 3003)
# ============================================

# Database
# alpha-etl reads ALPHA_ETL_DATABASE_URL from the shared section above.
DB_SCHEMA=alpha_raw

# Server Configuration (port 3003)
ALPHA_ETL_PORT=3003
HOST=127.0.0.1

# Webhook Authentication
# Used for both Pipedream webhooks (/webhooks/pipedream) and
# account-engine wallet fetch webhooks (/webhooks/wallet-fetch)
# Set the same secret in account-engine's ALPHA_ETL_WEBHOOK_SECRET
WEBHOOK_SECRET=your-pipedream-webhook-secret

# API Endpoints
DEBANK_API_URL=https://pro-openapi.debank.com
DEBANK_API_KEY=your-debank-api-key-optional
DEBANK_STRICT_ERRORS=true
HYPERLIQUID_API_URL=https://api-ui.hyperliquid.xyz
HYPERLIQUID_RATE_LIMIT_RPM=60
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=info

# Materialized View Refresh
# Enable automatic MV refresh after ETL completion for immediate data visibility
ENABLE_MV_REFRESH=true
MOCK_APIS=false

# CoinMarketCap API (Fear & Greed Index)
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key
COINMARKETCAP_API_URL=https://pro-api.coinmarketcap.com

# Alpha Vantage API (S&P500 stock prices)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 5 requests/minute, 25 requests/day
ALPHA_VANTAGE_API_KEY=your-alphavantage-api-key

# ============================================
# analytics-engine (port 8001)
# ============================================

# Environment
ENVIRONMENT=development
DEBUG=true

# Server (port 8001)
ANALYTICS_ENGINE_PORT=8001

# Database Access Control (Read-Only Configuration)
DATABASE_READ_ONLY=true
DATABASE_READ_ONLY_URL=postgresql+psycopg://readonly_user:readonly_password@aws-0-region.pooler.supabase.co:5432/postgres

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8000

# ============================================
# landing-page (port 3000)
# ============================================

NEXT_PUBLIC_ANALYTICS_API_URL=http://localhost:8001

# IPFS Gateways (used for fetching track-record snapshots)
# Defaults: https://ipfs.io/ipfs, https://cloudflare-ipfs.com/ipfs, https://dweb.link/ipfs
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs
NEXT_PUBLIC_IPFS_GATEWAY_FALLBACK=https://cloudflare-ipfs.com/ipfs

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# app-core / desktop web env
# ============================================

# API Configuration
VITE_ACCOUNT_API_URL=http://127.0.0.1:3004
VITE_ANALYTICS_ENGINE_URL=http://localhost:8001

# Optional podcast feed override. Defaults to production when blank.
VITE_PODCAST_API_URL=

# Wallet token balance provider switch: alchemy (default) or moralis.
VITE_DESKTOP_WALLET_PROVIDER=alchemy

# Shared cache window in seconds.
VITE_CACHE_MAX_AGE_SECONDS=3600
VITE_CACHE_STALE_WHILE_REVALIDATE_SECONDS=82800

# Privy embedded-wallet auth (Zap Wallet "Create Zap Wallet" button).
# Required: create an app at https://dashboard.privy.io and paste its App ID
# here. Must be a valid 25-character id: the frontend bundle app throws at boot
# when this is unset, and the Privy SDK throws "invalid Privy app ID" (crashing
# the /bundle page) if it is not exactly 25 characters.
# Enable Email/Google/Apple login methods in the Privy dashboard (Apple
# additionally needs Apple Developer credentials).
VITE_PRIVY_APP_ID=your-privy-app-id-here-25

# Desktop live wallet holdings / activity via Moralis.
# Blockchain(Moralis/Alchemy) API Key
VITE_MORALIS_API_KEY=
VITE_ALCHEMY_API_KEY=

# React Query Devtools: set to 1 only when debugging (uses extra browser memory)
VITE_ENABLE_RQ_DEVTOOLS=0

# Logging Configuration
# Enable debug logging in production (default: false)
VITE_ENABLE_DEBUG_LOGGING=false
# Enable development logging (default: true)
VITE_ENABLE_DEV_LOGGING=true

# ============================================
# podcast-pipeline (from-fed-to-chain, port 3000)
# ============================================

# LLM (OpenRouter - Anthropic / OpenAI compatible)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
LLM_THINKING_MODEL=