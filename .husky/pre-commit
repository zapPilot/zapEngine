#!/usr/bin/env sh
# Pre-commit orchestrator. For each app whose staged files changed, runs that
# app's pre-commit concurrently and streams each line of output prefixed with
# [name] so progress is visible live. Exit codes are collected so a single
# commit attempt surfaces every failure instead of stopping at the first one.

APPS_CONF="$(dirname "$0")/../apps.conf"

if [ "${FORCE_ALL:-}" = "1" ]; then
  CHANGED=$(awk -F'|' '/^[^#]/ && NF>=2 { print $2 "/" }' "$APPS_CONF")
else
  CHANGED=$(git diff --cached --name-only)
fi

LOG_DIR=$(mktemp -d)
trap 'rm -rf "$LOG_DIR"' EXIT

PIDS=""
NAMES=""

queue() {
  name=$1
  cmd=$2
  log_file="$LOG_DIR/$name.log"
  phase_file="$LOG_DIR/$name.phase"
  rc_file="$LOG_DIR/$name.rc"

  printf '▶ Starting: %s\n' "$name"

  (
    (
      set +e
      sh -c "$cmd"
      rc=$?
      printf '%s\n' "$rc" >"$rc_file"
      exit 0
    ) 2>&1 | tee "$log_file" | while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        "::phase::"*)
          printf '%s\n' "${line#::phase::}" >"$phase_file"
          ;;
        *)
          printf '[%s] %s\n' "$name" "$line"
          ;;
      esac
    done
  ) &

  PIDS="$PIDS $!"
  NAMES="$NAMES $name"
}

extract_failed_hook() {
  log_file=$1

  if [ ! -f "$log_file" ]; then
    return 0
  fi

  awk '
    /^[^[:space:]].*Failed$/ {
      line = $0
      sub(/[.][.][.].*$/, "", line)
      if (length(line) > 0) {
        print line
        exit
      }
    }
  ' "$log_file"
}

resolve_failure_phase() {
  name=$1
  phase_file="$LOG_DIR/$name.phase"
  log_file="$LOG_DIR/$name.log"

  if [ -s "$phase_file" ]; then
    cat "$phase_file"
    return
  fi

  phase=$(extract_failed_hook "$log_file")
  if [ -n "$phase" ]; then
    printf '%s\n' "$phase"
    return
  fi

  printf 'unknown\n'
}

print_failure_tail() {
  name=$1
  log_file="$LOG_DIR/$name.log"

  if [ ! -f "$log_file" ]; then
    printf '   (no output captured)\n'
    return
  fi

  tail_output=$(sed '/^::phase::/d' "$log_file" | tail -n 20)

  if [ -z "$tail_output" ]; then
    printf '   (no output captured)\n'
    return
  fi

  printf '%s\n' "$tail_output" | sed 's/^/   /'
}

while IFS='|' read -r name dir cmd || [ -n "$name" ]; do
  case "$name" in '#'*|'') continue ;; esac
  if printf '%s\n' "$CHANGED" | grep -q "^${dir}/"; then
    queue "$name" "cd $dir && $cmd"
  fi
done < "$APPS_CONF"

if [ -z "$NAMES" ]; then
  exit 0
fi

for pid in $PIDS; do
  wait "$pid" || true
done

FAILED=""
for n in $NAMES; do
  rc=$(cat "$LOG_DIR/$n.rc" 2>/dev/null)
  if [ "$rc" != "0" ]; then
    FAILED="$FAILED $n"
  fi
done

if [ -n "$FAILED" ]; then
  printf '\n❌ Pre-commit failed:\n'
  for n in $FAILED; do
    phase=$(resolve_failure_phase "$n")
    printf '   %-16s → phase: %s\n' "$n" "$phase"
  done
  for n in $FAILED; do
    printf '\n--- %s (last 20 lines) ---\n' "$n"
    print_failure_tail "$n"
  done
  exit 1
fi

printf '\n✅ All pre-commit checks passed\n'
