#!/usr/bin/env sh
# Pre-commit hook: fast feedback only.
# Runs lint-staged + drift checks on staged files. CI is the real gate.
# To run the full local gate manually before pushing: `pnpm verify`.
set -eu

# Keep deps in sync; near-instant when lockfile hasn't changed.
pnpm install --frozen-lockfile --prefer-offline --ignore-scripts

# Auto-sync strategy snapshot mirror (analytics-engine fixture -> landing-page data)
# so the strict drift check in lint:repo will pass.
pnpm lint:snapshot-sync:fix
git add apps/landing-page/src/data/strategy-snapshot.json
pnpm lint:repo

pnpm lint-staged

printf '\n✅ Pre-commit passed (CI runs the full gate)\n'
