#!/usr/bin/env sh
# Pre-commit hook: run fix-variants on --affected workspaces only.
# CI runs the same turbo tasks with check-variants on all workspaces.
# Task orchestration + parallelism + dependency graph are handled by turbo.
set -eu

pnpm turbo run \
  format \
  lint:fix \
  type-check \
  deadcode \
  dup:check \
  sql:audit \
  service-reachability \
  pylint:duplicate-check \
  test \
  --affected

# Workspace-level checks — always run, not tied to any package.
pnpm audit --audit-level=moderate
bash scripts/check-dead-env.sh

printf '\n✅ Pre-commit passed\n'
