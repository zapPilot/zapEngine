# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alpha-ETL Configuration (for wallet data fetch webhooks)
ALPHA_ETL_URL=http://localhost:3003
ALPHA_ETL_WEBHOOK_SECRET=your-secure-webhook-secret

# Server Configuration
PORT=3004
NODE_ENV=development

# Email Configuration (for weekly reports)
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# Admin Notification Configuration (for job failure alerts)
ADMIN_NOTIFICATIONS_ENABLED=true

# Analytics Engine Configuration
ANALYTICS_ENGINE_URL=http://127.0.0.1:8001

# API Key Authentication
ADMIN_API_KEY=your-secret-api-key-here

# Telegram Bot Configuration (for portfolio drift alerts)
# Create a bot via @BotFather on Telegram to get these values
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_NAME=YourBotName
TELEGRAM_WEBHOOK_SECRET=your-secure-webhook-secret
