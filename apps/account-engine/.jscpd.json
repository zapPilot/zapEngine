{
  "ignore": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/test/**",
    "**/test-utils/**",
    "**/database.types.ts",
    "dist/**",
    "node_modules/**",
    "coverage/**",
    ".husky/**",
    "scripts/**"
  ],
  "ignorePattern": [
    "import\\s.*from\\s.*",
    "import\\s*\\{[\\s\\S]*?\\}\\s*from\\s*'[^']*'"
  ],
  "format": [
    "typescript"
  ]
}
