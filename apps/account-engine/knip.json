{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main.ts"],
  "project": ["src/**/*.ts"],
  "ignore": [
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "test/**",
    "scripts/**",
    "src/test-utils/**",
    "jest.setup.ts",
    "nest-cli.json",
    "eslint.config.mjs",
    "src/types/database.types.ts"
  ],
  "ignoreDependencies": [
    "@zapengine/types",
    "@zapengine/tsconfig",
    "tsconfig-paths"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "jest": {
    "config": ["test/jest-e2e.json"],
    "entry": ["src/**/*.spec.ts", "test/**/*.e2e-spec.ts"]
  }
}
