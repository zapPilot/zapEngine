{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": [
    "src/**/*.ts"
  ],
  "ignore": [
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "test/**",
    "scripts/**",
    "src/test-utils/**",
    "jest.setup.ts",
    "nest-cli.json",
    "src/types/database.types.ts"
  ],
  "ignoreDependencies": [
    "@zapengine/eslint-config",
    "@zapengine/types",
    "tsconfig-paths"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "eslint": {
    "config": [
      "eslint.config.mjs"
    ]
  },
  "jest": {
    "config": ["test/jest-e2e.json"],
    "entry": ["src/**/*.spec.ts", "test/**/*.e2e-spec.ts"]
  }
}
