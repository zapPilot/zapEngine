{
  "name": "@zapengine/account-engine",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --include \"../../packages/*/dist/**/*.js\" src/main.ts",
    "start": "node dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "^0.7.4",
    "@privy-io/node": "^0.21.0",
    "@supabase/supabase-js": "catalog:",
    "@zapengine/intent-engine": "workspace:*",
    "@zapengine/types": "workspace:*",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "nodemailer": "catalog:",
    "telegraf": "catalog:",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/nodemailer": "^7.0.2",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
