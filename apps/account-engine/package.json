{
  "name": "account-engine",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "deadcode": "knip --exports --dependencies",
    "dup:check": "jscpd src --config .jscpd.json",
    "pre-commit": "sh pre-commit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@zapengine/types": "workspace:*",
    "@hono/node-server": "^1.19.4",
    "@hono/zod-validator": "^0.7.4",
    "@supabase/supabase-js": "^2.56.0",
    "dotenv": "^17.4.1",
    "hono": "^4.10.1",
    "nodemailer": "^7.0.6",
    "telegraf": "^4.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@zapengine/tsconfig": "workspace:*",
    "@eslint/js": "^9.18.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "jscpd": "^4.0.5",
    "knip": "^5.66.4",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "roots": ["<rootDir>/test/unit"],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.jest.json" }]
    },
    "collectCoverageFrom": ["src/**/*.(t|j)s"],
    "coveragePathIgnorePatterns": [
      "/node_modules/", "/dist/", "src/test-utils",
      "\\.dto\\.ts$", "\\.interface\\.ts$", "src/main\\.ts",
      "src/container\\.ts", "src/common/constants/", "src/types/",
      "src/users/constants/", "src/users/interfaces/", "/index\\.ts$"
    ],
    "coverageThreshold": {
      "global": { "branches": 90, "functions": 95, "lines": 95, "statements": 95 }
    },
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
    "testTimeout": 30000,
    "detectOpenHandles": true,
    "forceExit": true,
    "clearMocks": true,
    "restoreMocks": true,
    "moduleNameMapper": {
      "^@zapengine/types/(.*)$": "<rootDir>/__mocks__/@zapengine/types/$1",
      "^@common/(.*)$": "<rootDir>/src/common/$1",
      "^@database/(.*)$": "<rootDir>/src/database/$1",
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@users/(.*)$": "<rootDir>/src/users/$1",
      "^@config/(.*)$": "<rootDir>/src/config/$1",
      "^@db-types/(.*)$": "<rootDir>/src/types/$1",
      "^@container$": "<rootDir>/src/container.ts",
      "^@routes/(.*)$": "<rootDir>/src/routes/$1",
      "^@test-utils$": "<rootDir>/test/test-utils/index.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
