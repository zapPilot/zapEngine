{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/container": ["./src/container.ts"],
      "@/test-utils": ["./test/test-utils/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*.ts",
    "tsconfig.test.json"
  ],
  "exclude": ["node_modules", "dist"]
}
