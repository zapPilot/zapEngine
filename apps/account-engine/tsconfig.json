{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@common/*": ["src/common/*"],
      "@database/*": ["src/database/*"],
      "@modules/*": ["src/modules/*"],
      "@users/*": ["src/users/*"],
      "@config/*": ["src/config/*"],
      "@db-types/*": ["src/types/*"],
      "@container": ["src/container.ts"],
      "@routes/*": ["src/routes/*"],
      "@test-utils": ["test/test-utils/index.ts"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true
  }
}
