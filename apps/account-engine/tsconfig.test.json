{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "rootDir": ".",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/container": ["./src/container.ts"],
      "@/test-utils": ["./test/test-utils/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}