{
  "$schema": "https://json.schemastore.org/jscpd.json",
  "format": [
    "typescript"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/__tests__/**",
    "**/coverage/**"
  ],
  "ignorePattern": [
    "import\\s.*from\\s.*",
    "import\\s*\\{[\\s\\S]*?\\}\\s*from\\s*'[^']*'"
  ]
}
