{
  "$schema": "https://json.schemastore.org/jscpd.json",
  "threshold": 3.0,
  "reporters": [
    "console"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/__tests__/**",
    "**/coverage/**"
  ],
  "gitignore": true,
  "minLines": 5,
  "minTokens": 120,
  "exitCode": 1,
  "absolute": false,
  "skipComments": true
}