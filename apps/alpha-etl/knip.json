{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["scripts/**/*.ts"],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "tests/**",
    "vitest.config.ts"
  ],
  "ignoreDependencies": [
    "@zapengine/eslint-config",
    "@zapengine/types"
  ],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "eslint": {
    "config": [
      "eslint.config.mjs"
    ]
  },
  "vitest": {
    "config": [
      "vitest.config.ts"
    ],
    "entry": [
      "tests/**/*.{test,spec}.ts",
      "src/**/__tests__/*.{test,spec}.ts"
    ]
  }
}
