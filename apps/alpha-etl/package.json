{
  "name": "alpha-etl",
  "version": "1.0.0",
  "description": "DeFi APR data ETL pipeline",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "deadcode": "knip --exports --dependencies",
    "dup:check": "jscpd src --config .jscpd.json",
    "clean": "rm -rf dist coverage"
  },
  "keywords": ["defi", "etl", "apr", "postgres"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@zapengine/types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@zapengine/tsconfig": "workspace:*",
    "prettier": "^3.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.20.0",
    "fast-check": "^4.4.0",
    "jscpd": "^4.0.5",
    "knip": "^5.66.4",
    "supertest": "^6.3.3",
    "tsx": "^4.6.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
