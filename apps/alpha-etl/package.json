{
  "name": "@zapengine/alpha-etl",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Alpha data ETL pipeline",
  "main": "dist/app.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src scripts --max-warnings 0",
    "lint:fix": "eslint src scripts --fix",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage",
    "backfill:sp500": "tsx scripts/backfill-sp500.ts"
  },
  "keywords": [
    "etl",
    "alpha",
    "postgres"
  ],
  "author": "",
  "dependencies": {
    "@zapengine/types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "prettier": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "catalog:",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "supertest": "^6.3.3",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
