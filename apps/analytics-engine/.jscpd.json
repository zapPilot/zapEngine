{
  "format": ["python"],
  "ignore": [
    "src/tests/**",
    "**/__pycache__/**",
    "src/services/backtesting/strategies/**",
    "src/services/interfaces/**"
  ],
  "ignorePattern": [
    "from\\s+[^\\n]+\\s+import\\s+\\([\\s\\S]*?\\)",
    "from\\s+[^\\n]+\\s+import\\s+[^\\n]+",
    "import\\s+[^\\n]+"
  ]
}
