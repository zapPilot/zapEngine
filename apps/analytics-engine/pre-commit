#!/usr/bin/env sh
set -eu

phase() {
  printf '::phase::%s\n' "$1"
}

phase format
pnpm run format

phase lint:fix
pnpm run lint:fix

printf "\n🔎 Ruff + mypy\n"
phase lint
pnpm run lint

printf "\n🧰 Type check (mypy)\n"
phase type-check
pnpm run type-check

printf "\n🧹 Format check\n"
phase format:check
pnpm run format:check

printf "\n🔎 Deadcode check\n"
phase deadcode
pnpm run deadcode

printf "\n🔎 Duplicate check\n"
phase dup:check
pnpm run dup:check

printf "\n🔎 SQL parameter audit\n"
phase sql:audit
pnpm run sql:audit

printf "\n🔎 Service reachability\n"
phase service-reachability
pnpm run service-reachability

printf "\n🔎 Pylint duplicate check\n"
phase pylint:duplicate-check
pnpm run pylint:duplicate-check

printf "\n🧪 Tests (pre-commit)\n"
phase test:pre-commit
pnpm run test:pre-commit
