{
  "name": "@zapengine/app",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "entrypoint.js",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:web": "expo start --web",
    "postinstall": "node scripts/install-playwright.mjs",
    "eas-build-post-install": "cd ../.. && pnpm turbo run build --filter=@zapengine/app-core",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:eas:login": "pnpm dlx eas-cli@20.5.1 login",
    "android:eas:init": "pnpm dlx eas-cli@20.5.1 init",
    "android:credentials": "pnpm dlx eas-cli@20.5.1 credentials --platform android",
    "android:version:init": "pnpm dlx eas-cli@20.5.1 build:version:set --platform android",
    "android:release": "pnpm dlx eas-cli@20.5.1 build --platform android --profile production",
    "android:release:local": "mkdir -p dist/android && pnpm dlx eas-cli@20.5.1 build --platform android --profile production --local --output dist/android/zap-pilot-release.aab",
    "android:submit": "pnpm dlx eas-cli@20.5.1 submit --platform android --profile production --latest",
    "android:publish": "pnpm dlx eas-cli@20.5.1 build --platform android --profile production --auto-submit",
    "ios": "expo run:ios",
    "build": "EXPO_NO_TELEMETRY=1 expo export --platform android --output-dir dist/android && EXPO_NO_TELEMETRY=1 expo export --platform ios --output-dir dist/ios",
    "build:web": "EXPO_NO_TELEMETRY=1 expo export --platform web --output-dir dist/web --source-maps",
    "check:web-native-leaks": "node scripts/check-web-native-leaks.mjs",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"*.{js,json,md,mjs,ts}\" \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"*.{js,json,md,mjs,ts}\" \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "EXPO_PUBLIC_PRIVY_APP_ID=e2eprivyappidplaceholder0 EXPO_PUBLIC_PRIVY_CLIENT_ID=e2eprivyclientplaceholder pnpm run build:web && PLAYWRIGHT_PORT=3100 playwright test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage .vitest-reports .expo"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@expo/metro-runtime": "~57.0.2",
    "@privy-io/expo": "^0.69.4",
    "@privy-io/expo-native-extensions": "^0.0.11",
    "@privy-io/react-auth": "^3.29.2",
    "@react-native-community/slider": "5.2.0",
    "@tanstack/react-query": "^5.85.3",
    "@zapengine/app-core": "workspace:*",
    "@zapengine/design-tokens": "workspace:*",
    "@zapengine/types": "workspace:*",
    "expo": "~57.0.1",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-audio": "~57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "57.0.3",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-video": "~57.0.1",
    "expo-web-browser": "~57.0.0",
    "fast-text-encoding": "^1.0.6",
    "hls.js": "^1.6.5",
    "lucide-react-native": "^0.523.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "0.2.6",
    "react-native-get-random-values": "^2.0.0",
    "react-native-passkeys": "^0.4.1",
    "react-native-qrcode-styled": "0.3.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "14.0.1",
    "react-native-worklets": "0.10.0",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@expo/metro-config": "~57.0.2",
    "@playwright/test": "^1.56.1",
    "@types/node": "catalog:",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/knip-config": "workspace:*",
    "babel-preset-expo": "~57.0.1",
    "eslint": "catalog:",
    "eslint-config-expo": "~57.0.0",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "~3.4.19",
    "typescript": "~6.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
