{
  "name": "@zapengine/desktop-electron",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "package": "pnpm --dir ../mobile-v2 run build:web && pnpm run build && electron-builder --mac dmg",
    "lint": "eslint src tests scripts --max-warnings 0",
    "lint:fix": "eslint src tests scripts --fix",
    "format": "prettier --write \"*.{json,md,mjs,ts,yml}\" \"scripts/**/*.mjs\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"*.{json,md,mjs,ts,yml}\" \"scripts/**/*.mjs\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "deadcode": "knip",
    "deadcode:fix": "knip --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage release"
  },
  "dependencies": {
    "@zapengine/app-core": "workspace:*",
    "@zapengine/types": "workspace:*",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
