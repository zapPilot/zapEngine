{
  "format": ["typescript", "javascript", "tsx", "jsx"],
  "ignore": [
    "**/node_modules/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/tests/**",
    "**/*.d.ts",
    "**/dist/**",
    "**/coverage/**",
    "src-tauri/**"
  ],
  "ignorePattern": [
    "import\\s.*from\\s.*",
    "import\\s+type\\s*\\{[\\s\\S]*?\\}\\s*from\\s*['\"][^'\"]+['\"];?",
    "import\\s*\\{[\\s\\S]*?\\}\\s*from\\s*['\"][^'\"]+['\"];?"
  ]
}
