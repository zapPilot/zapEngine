{
  "name": "@zapengine/desktop",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "package": "tauri build --bundles dmg",
    "lint": "eslint tests --max-warnings 0",
    "lint:fix": "eslint tests --fix",
    "format": "prettier --write \"*.json\" \"*.mjs\" \"*.ts\" \"tests/**/*.ts\" \"src-tauri/**/*.json\"",
    "format:check": "prettier --check \"*.json\" \"*.mjs\" \"*.ts\" \"tests/**/*.ts\" \"src-tauri/**/*.json\"",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs tests",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf coverage src-tauri/target"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "catalog:",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
