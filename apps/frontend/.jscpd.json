{
  "format": ["typescript", "javascript", "tsx", "jsx"],
  "ignore": [
    "**/node_modules/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/tests/**",
    "**/*.d.ts",
    "**/dist/**",
    "**/coverage/**",
    ".jscpd/**",
    "jscpd-report/**",
    "src/config/chains/definitions.ts",
    "src/components/wallet/portfolio/analytics/AnalyticsView.tsx",
    "src/components/wallet/portfolio/analytics/components/AnalyticsHeader.tsx",
    "src/app/bundle/BundlePageClient.tsx",
    "src/components/wallet/portfolio/views/invest/trading/components/TransactionPanel.tsx",
    "src/hooks/wallet/usePrivyWalletBackend.ts",
    "src/hooks/wallet/useWagmiWalletBackend.ts",
    "src/hooks/useGmxDeposit.ts",
    "src/hooks/useWithdraw.ts",
    "src/components/WalletManager/components/ConnectWalletButton.tsx",
    "src/components/WalletManager/components/CreateZapWalletButton.tsx"
  ],
  "ignorePattern": [
    "import\\s.*from\\s.*",
    "import\\s+type\\s*\\{[\\s\\S]*?\\}\\s*from\\s*['\"][^'\"]+['\"];?",
