{
  "name": "@zapengine/frontend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "postinstall": "playwright install chromium",
    "dev": "cross-env VITE_ENABLE_RQ_DEVTOOLS=0 VITE_ENABLE_LOG_VIEWER=0 vite",
    "dev:debug": "cross-env VITE_ENABLE_RQ_DEVTOOLS=1 VITE_ENABLE_LOG_VIEWER=1 vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vitest run",
    "test:ci": "cross-env NODE_OPTIONS=--max-old-space-size=1024 pnpm run test:coverage && pnpm run test:e2e",
    "test:unit": "cross-env NODE_OPTIONS=--max-old-space-size=1024 vitest run tests/unit",
    "test:watch": "vitest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=1024 node scripts/run-sharded-coverage.js",
    "test:e2e": "cross-env PLAYWRIGHT_PORT=3099 playwright test",
    "test:e2e:safe": "cross-env PLAYWRIGHT_PORT=3099 node scripts/run-e2e-safe.js",
    "deadcode": "node scripts/run-deadcode.js default",
    "deadcode:fix": "node scripts/run-deadcode.js default --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "test:safeall": "cross-env NODE_OPTIONS=--max-old-space-size=1024 pnpm run test:coverage && pnpm run test:e2e:safe",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage .vitest-reports"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-devtools": "^5.85.3",
    "@zapengine/design-tokens": "workspace:*",
    "@zapengine/intent-engine": "workspace:*",
    "@zapengine/types": "workspace:*",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.19.1",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.6.0",
    "viem": "catalog:",
    "vite-plugin-pwa": "^1.2.0",
    "wagmi": "^3.6.1",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "baseline-browser-mapping": "^2.0.0",
    "cross-env": "^10.0.0",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "postcss": "^8.4.47",
    "prettier": "catalog:",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
