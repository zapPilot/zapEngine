{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/app/**/*.{ts,tsx}"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/config/index.ts",
    "src/hooks/index.ts",
    "src/lib/index.ts",
    "src/types/index.ts",
    "src/test-utils/index.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@zapengine/eslint-config",
    "postcss",
    "eslint-config-next",
    "eslint-config-prettier"
  ],
  "eslint": {
    "config": ["eslint.config.mjs"]
  }
}
