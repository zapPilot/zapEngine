{
  "name": "@zapengine/landing-page",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf .next out coverage"
  },
  "dependencies": {
    "@next/third-parties": "^15.3.4",
    "@zapengine/types": "workspace:*",
    "dotenv": "catalog:",
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^13.0.8",
    "fumadocs-ui": "^15.8.5",
    "lucide-react": "catalog:",
    "next": "^15.5.7",
    "react": "catalog:",
    "react-dom": "catalog:",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/design-tokens": "workspace:*",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
