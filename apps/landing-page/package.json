{
  "name": "@zapengine/landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "deadcode": "node scripts/run-deadcode.js default",
    "deadcode:ci": "node scripts/run-deadcode.js ci",
    "deadcode:fix": "node scripts/run-deadcode.js fix",
    "deadcode:check": "node scripts/run-deadcode.js check",
    "deadcode:exports": "ts-prune -p tsconfig.tsprune.json",
    "dup:check": "jscpd src --gitignore --min-lines 5 --threshold 12",
    "dup:all": "pnpm run dup:check",
    "clean": "rm -rf .next out coverage",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@next/third-parties": "^15.3.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.19.1",
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^13.0.8",
    "fumadocs-ui": "^15.8.5",
    "lucide-react": "^0.523.0",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.3.4",
    "jscpd": "^4.0.5",
    "jsdom": "^25.0.1",
    "knip": "^5.68.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "23.x"
  }
}
