{
  "name": "@zapengine/mobile-v2",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "entrypoint.js",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "EXPO_NO_TELEMETRY=1 expo export --platform android --output-dir dist/android && EXPO_NO_TELEMETRY=1 expo export --platform ios --output-dir dist/ios",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"*.{js,json,md,mjs,ts}\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"*.{js,json,md,mjs,ts}\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage .vitest-reports .expo"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@privy-io/expo": "^0.69.4",
    "@privy-io/expo-native-extensions": "^0.0.11",
    "expo": "~57.0.1",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "57.0.3",
    "expo-linking": "~57.0.1",
    "expo-secure-store": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "fast-text-encoding": "^1.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-passkeys": "^0.4.1",
    "react-native-webview": "14.0.1"
  },
  "devDependencies": {
    "@expo/metro-config": "~57.0.2",
    "@types/node": "catalog:",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "catalog:",
    "@zapengine/knip-config": "workspace:*",
    "eslint": "catalog:",
    "eslint-config-expo": "~57.0.0",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "~6.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
