  "captions": [
    {
      "startMs": 120,
      "endMs": 3780,
      "text": "各位聽眾朋友，今天我們來聊\n一個有點反直覺的故事。"
    },
    {
      "startMs": 3780,
      "endMs": 6620,
      "text": "2026 年 6 月底，一場「熱穹頂」——"
    },
    {
      "startMs": 6620,
      "endMs": 10260,
      "text": "就是那種讓熱空氣像鍋蓋一樣\n蓋住某個區域，"
    },
    {
      "startMs": 10260,
      "endMs": 13040,
      "text": "溫度飆升到異常高點的極端氣象——"
    },
    {
      "startMs": 13040,
      "endMs": 16030,
      "text": "把美國最大的電網 PJM\n逼到了牆角。"
    },
    {
      "startMs": 16030,
      "endMs": 18450,
      "text": "PJM 全名叫 Pennsylvania–\nNew Jersey–Maryland"
    },
    {
      "startMs": 18450,
      "endMs": 20350,
      "text": "Interconnection，"
    },
    {
      "startMs": 20350,
      "endMs": 23150,
      "text": "是北美規模最大的區域傳輸組織，"
    },
    {
      "startMs": 23150,
      "endMs": 26190,
      "text": "服務範圍涵蓋 13 個州\n和華盛頓特區，"
    },
    {
      "startMs": 26190,
      "endMs": 27760,
      "text": "大概六千七百萬人。"
    },
    {
      "startMs": 27760,
      "endMs": 31590,
      "text": "7 月 1 號，這個電網創下了\n歷史第二高的用電負荷，"
    },
    {
      "startMs": 31590,
      "endMs": 34090,
      "text": "達到 161,910 兆瓦。"
    },
    {
      "startMs": 34090,
      "endMs": 36170,
      "text": "第二天，執行備用容量——"
    },
    {
      "startMs": 36170,
      "endMs": 39460,
      "text": "就是電網手邊還能立刻調用的\n額外發電能力——"
    },
    {
      "startMs": 39460,
      "endMs": 43660,
      "text": "從 10,996 兆瓦直接暴跌到\n5,091 兆瓦，"
    },
    {
      "startMs": 43660,
      "endMs": 45790,
      "text": "緩衝墊薄得讓人心驚膽戰。"
    },
    {
      "startMs": 45790,
      "endMs": 49440,
      "text": "所以，6 月 30 號，美國能源部部長\nChris Wright"
    },
    {
      "startMs": 49440,
      "endMs": 51080,
      "text": "簽下了兩張緊急命令，"
    },
    {
      "startMs": 51080,
      "endMs": 53660,
      "text": "當天晚上 11 點 59 分生效。"
    },
    {
      "startMs": 53660,
      "endMs": 58210,
      "text": "第一張命令允許指定的發電機組\n臨時突破環保排放上限，"
    },
    {
      "startMs": 58210,
      "endMs": 59230,
      "text": "全力發電。"
    },
    {
      "startMs": 59230,
      "endMs": 61820,
      "text": "第二張命令更猛：作為最後手段，"
    },
    {
      "startMs": 61820,
      "endMs": 65630,
      "text": "它允許電網強制要求\n50 兆瓦以上的大型用電戶——"
    },
    {
      "startMs": 65630,
      "endMs": 68170,
      "text": "比如資料中心，還有比特幣礦場——"
    },
    {
      "startMs": 68170,
      "endMs": 70520,
      "text": "在 15 分鐘內切斷電網的供電，"
    },
    {
      "startMs": 70520,
      "endMs": 72680,
      "text": "改用他們自己的備用發電機。"
    },
    {
      "startMs": 72680,
      "endMs": 77030,
      "text": "7 月 2 號，批發電價飆到\n每兆瓦時超過 2,000 美元，"
    },
    {
      "startMs": 77030,
      "endMs": 82260,
      "text": "Western Hub 的日前結算價\n衝到 1,222.75 美元／兆瓦時，"
    },
    {
      "startMs": 82260,
      "endMs": 85400,
      "text": "比去年同期的可比峰值\n翻了將近三倍。"
    },
    {
      "startMs": 85400,
      "endMs": 87780,
      "text": "從 7 月 1 號到 7 月 3 號，"
    },
    {
      "startMs": 87780,
      "endMs": 90000,
      "text": "PJM 連續發布高溫預警……"
    }
  ]
}
