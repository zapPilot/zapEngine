{
  "name": "@zapengine/podcast-pipeline",
  "version": "0.0.1",
  "description": "Hono service: article -> LLM script -> TTS -> HLS -> episode storage (from-fed-to-chain).",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "prompts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\" \"*.config.*\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.config.*\" \"*.json\"",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deadcode": "knip --exports --dependencies",
    "deadcode:fix": "knip --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "clean": "rm -rf dist coverage .jscpd tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@hono/node-server": "^1.19.6",
    "@mozilla/readability": "^0.6.0",
    "@supabase/supabase-js": "^2.84.0",
    "dotenv": "^17.2.3",
    "fluent-ffmpeg": "^2.1.3",
    "hono": "^4.10.7",
    "jsdom": "catalog:",
    "openai": "^6.34.0",
    "opencc-js": "^1.3.0"
  },
  "devDependencies": {
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsdom": "^28.0.1",
    "@types/node": "catalog:",
    "@types/opencc-js": "^1.0.3",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
