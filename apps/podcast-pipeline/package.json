{
  "name": "@zapengine/podcast-pipeline",
  "version": "0.0.1",
  "description": "Hono service: article -> LLM script -> TTS -> HLS -> episode storage (from-fed-to-chain).",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "assets",
    "dist",
    "prompts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "video:render": "tsx src/services/video/cli.ts",
    "video:storyboard:smoke": "tsx src/services/video/storyboard/smoke-cli.ts",
    "video:r2-canary": "tsx src/services/video/r2-playback-canary.ts",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"examples/**/*.json\" \"*.config.*\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"examples/**/*.json\" \"*.config.*\" \"*.json\"",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deadcode": "knip --files --exports --dependencies",
    "deadcode:fix": "knip --files --exports --dependencies --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "security:audit": "pnpm audit --prod --audit-level=moderate",
    "clean": "rm -rf dist coverage .jscpd tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/lib-storage": "^3.940.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@hono/node-server": "catalog:",
    "@mozilla/readability": "^0.6.0",
    "@supabase/supabase-js": "catalog:",
    "@zapengine/design-tokens": "workspace:*",
    "dotenv": "catalog:",
    "fluent-ffmpeg": "^2.1.3",
    "hono": "catalog:",
    "jsdom": "catalog:",
    "openai": "^6.34.0",
    "opencc-js": "^1.3.0",
    "react": "catalog:",
    "satori": "0.28.0",
    "sharp": "0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsdom": "^28.0.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
