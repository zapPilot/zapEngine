{
  "name": "zap-engine",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint:config": "tsx scripts/lint/config-drift.ts",
    "lint:config:fix": "tsx scripts/lint/config-drift.ts --fix",
    "lint:snapshot-sync:fix": "tsx scripts/lint/snapshot-sync.ts --fix",
    "lint:scripts": "tsx scripts/lint/scripts-drift.ts",
    "lint:snapshot-sync": "tsx scripts/lint/snapshot-sync.ts",
    "lint:dead-env": "bash scripts/check-dead-env.sh",
    "lint:repo": "pnpm lint:config && pnpm lint:scripts && pnpm lint:snapshot-sync",
    "build": "turbo run build",
    "build:core": "turbo run build --filter=!@zapengine/mobile",
    "dev": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/frontend --filter=@zapengine/account-engine --filter=@zapengine/analytics-engine --filter=@zapengine/types --filter=@zapengine/intent-engine",
    "dev:full": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/frontend --filter=@zapengine/account-engine --filter=@zapengine/analytics-engine --filter=@zapengine/types --filter=@zapengine/intent-engine",
    "dev:lite": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/frontend --filter=@zapengine/account-engine --filter=@zapengine/types --filter=@zapengine/intent-engine",
    "dev:analytics": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/analytics-engine",
    "dev:frontend": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/frontend --filter=@zapengine/types --filter=@zapengine/intent-engine",
    "dev:api": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/account-engine --filter=@zapengine/types --filter=@zapengine/intent-engine",
    "dev:landing": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier --filter=@zapengine/landing-page",
    "dev:all": "turbo run dev --cache=local:rw --ui=stream --no-update-notifier",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test:coverage",
    "coverage:summary": "turbo run test:coverage --filter=!@zapengine/mobile && tsx scripts/coverage-summary.ts",
    "coverage:check": "pnpm coverage:summary && tsx scripts/coverage-regression.ts",
    "coverage:scripts:test": "tsx --test scripts/coverage-summary.test.ts scripts/coverage-regression.test.ts",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:check:core": "turbo run format:check --filter=!@zapengine/mobile",
    "deadcode": "turbo run deadcode",
    "dup:check": "turbo run dup:check",
    "contracts:export": "tsx scripts/contracts/export_zod_schemas.ts",
    "contracts:check:built": "pnpm contracts:export && cd apps/analytics-engine && uv run python ../../scripts/contracts/check_pydantic_parity.py",
    "contracts:check": "pnpm prebuild:packages && pnpm contracts:check:built",
    "prebuild:packages": "turbo run build --filter=./packages/*",
    "check:local": "pnpm format:check && pnpm lint:repo && pnpm contracts:check && turbo run lint type-check deadcode:fix test --affected && pnpm lint:dead-env",
    "verify": "pnpm check:local",
    "verify:full": "pnpm check:ci",
    "verify:no-mobile": "pnpm check:ci:core",
    "verify:frontend": "turbo run lint type-check test --filter=@zapengine/frontend",
    "verify:account-engine": "turbo run lint type-check test --filter=@zapengine/account-engine",
    "verify:analytics-engine": "turbo run lint type-check test --filter=@zapengine/analytics-engine",
    "verify:alpha-etl": "turbo run lint type-check test --filter=@zapengine/alpha-etl",
    "verify:landing-page": "turbo run lint type-check test --filter=@zapengine/landing-page",
    "verify:podcast-pipeline": "turbo run lint type-check test --filter=@zapengine/podcast-pipeline",
    "verify:packages": "turbo run lint type-check test --filter=./packages/*",
    "check:ci": "pnpm format:check && pnpm lint:repo && pnpm contracts:check && turbo run lint type-check deadcode dup:check test:ci && turbo run sql:audit service-reachability pylint:duplicate-check --filter=@zapengine/analytics-engine",
    "check:ci:core": "pnpm format:check:core && pnpm lint:repo && pnpm contracts:check && turbo run lint type-check deadcode dup:check test:ci --filter=!@zapengine/mobile && turbo run sql:audit service-reachability pylint:duplicate-check --filter=@zapengine/analytics-engine",
    "security:audit": "pnpm audit --audit-level=moderate && turbo run security:audit",
    "security:audit:core": "pnpm audit --audit-level=moderate && turbo run security:audit --filter=!@zapengine/mobile",
    "verify:account-engine-package": "bash scripts/verify-account-engine-package.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "jscpd": "catalog:",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "catalog:",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "protobufjs@<=7.5.7": ">=7.5.8",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@<11.1.1": ">=11.1.1",
      "qs@>=6.11.1 <6.15.2": ">=6.15.2"
    }
  },
  "lint-staged": {
    "apps/account-engine/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/account-engine exec eslint --fix",
      "pnpm --filter @zapengine/account-engine exec prettier --write"
    ],
    "apps/alpha-etl/**/*.{ts,js}": [
      "pnpm --filter @zapengine/alpha-etl exec eslint --fix",
      "pnpm --filter @zapengine/alpha-etl exec prettier --write"
    ],
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/frontend exec eslint --fix",
      "pnpm --filter @zapengine/frontend exec prettier --write"
    ],
    "apps/landing-page/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/landing-page exec eslint --fix",
      "pnpm --filter @zapengine/landing-page exec prettier --write"
    ],
    "apps/podcast-pipeline/**/*.ts": [
      "pnpm --filter @zapengine/podcast-pipeline exec eslint --fix",
      "pnpm --filter @zapengine/podcast-pipeline exec prettier --write"
    ],
    "packages/**/*.{js,mjs,cjs,ts,tsx,json,md}": [
      "pnpm --filter @zapengine/eslint-config exec prettier --write"
    ],
    "apps/analytics-engine/**/*.py": [
      "pnpm --filter @zapengine/analytics-engine exec uv run ruff check --fix"
    ]
  }
}
