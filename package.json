{
  "name": "zap-engine",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "bash scripts/build.sh",
    "type-check": "turbo run type-check",
    "test": "bash scripts/test.sh",
    "lint": "bash scripts/lint.sh",
    "format": "bash scripts/format.sh",
    "deadcode": "turbo run deadcode",
    "dup:check": "turbo run dup:check",
    "verify": "bash scripts/verify.sh",
    "contracts": "bash scripts/contracts.sh",
    "security": "bash scripts/security.sh",
    "coverage": "bash scripts/coverage.sh",
    "track-record:generate": "tsx scripts/track-record/generate-daily-snapshot.ts",
    "track-record:publish": "tsx scripts/track-record/publish-daily-snapshot.ts",
    "track-record:verify": "tsx scripts/track-record/verify-track-record.ts",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "husky": "^9.1.7",
    "jscpd": "catalog:",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "tsx": "catalog:",
    "turbo": "^2.9.18",
    "viem": "catalog:"
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "apps/account-engine/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/account-engine exec eslint --fix",
      "pnpm --filter @zapengine/account-engine exec prettier --write"
    ],
    "apps/alpha-etl/**/*.{ts,js}": [
      "pnpm --filter @zapengine/alpha-etl exec eslint --fix",
      "pnpm --filter @zapengine/alpha-etl exec prettier --write"
    ],
    "apps/desktop/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/desktop exec eslint --fix",
      "pnpm --filter @zapengine/desktop exec prettier --write"
    ],
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/frontend exec eslint --fix",
      "pnpm --filter @zapengine/frontend exec prettier --write"
    ],
    "apps/landing-page/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/landing-page exec eslint --fix",
      "pnpm --filter @zapengine/landing-page exec prettier --write"
    ],
    "apps/podcast-pipeline/**/*.ts": [
      "pnpm --filter @zapengine/podcast-pipeline exec eslint --fix",
      "pnpm --filter @zapengine/podcast-pipeline exec prettier --write"
    ],
    "packages/**/*.{js,mjs,cjs,ts,tsx,json,md}": [
      "pnpm --filter @zapengine/eslint-config exec prettier --write"
    ],
    "apps/analytics-engine/**/*.py": [
      "pnpm --filter @zapengine/analytics-engine exec uv run ruff check --fix",
      "pnpm --filter @zapengine/analytics-engine exec uv run ruff format"
    ]
  }
}
