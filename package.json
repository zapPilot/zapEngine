{
  "name": "zap-engine",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=frontend --filter=account-engine --filter=analytics-engine --parallel",
    "dev:landing": "turbo run dev --filter=landing-page",
    "dev:all": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test:coverage",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "deadcode": "turbo run deadcode",
    "dup:check": "turbo run dup:check",
    "verify:account-engine-package": "bash scripts/verify-account-engine-package.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "apps/account-engine/**/*.{ts,tsx}": [
      "pnpm --filter account-engine exec eslint --fix",
      "pnpm --filter account-engine exec prettier --write"
    ],
    "apps/alpha-etl/**/*.{ts,js}": [
      "pnpm --filter alpha-etl exec eslint --fix",
      "pnpm --filter alpha-etl exec prettier --write"
    ],
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter frontend exec eslint --fix",
      "pnpm --filter frontend exec prettier --write"
    ],
    "apps/landing-page/**/*.{ts,tsx}": [
      "pnpm --filter landing-page exec eslint --fix",
      "pnpm --filter landing-page exec prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "pnpm exec eslint --fix",
      "pnpm exec prettier --write"
    ],
    "apps/analytics-engine/**/*.py": [
      "pnpm --filter analytics-engine exec uv run ruff check --fix"
    ]
  }
}
