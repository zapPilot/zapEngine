{
  "name": "zap-engine",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=frontend --filter=account-engine --filter=analytics-engine --parallel",
    "dev:landing": "turbo run dev --filter=landing-page",
    "dev:all": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "deadcode": "turbo run deadcode",
    "dup:check": "turbo run dup:check",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "husky": "^9.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
