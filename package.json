{
  "name": "zap-engine",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@zapengine/frontend --filter=@zapengine/account-engine --filter=@zapengine/analytics-engine --parallel",
    "dev:landing": "turbo run dev --filter=@zapengine/landing-page",
    "dev:all": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test:coverage",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "deadcode": "turbo run deadcode",
    "dup:check": "turbo run dup:check",
    "check:local": "pnpm format:check && turbo run lint type-check test --affected && bash scripts/check-dead-env.sh",
    "check:ci": "pnpm format:check && turbo run lint type-check deadcode dup:check sql:audit service-reachability pylint:duplicate-check test:ci && bash scripts/check-dead-env.sh",
    "security:audit": "pnpm audit --audit-level=moderate",
    "verify:account-engine-package": "bash scripts/verify-account-engine-package.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "apps/account-engine/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/account-engine exec eslint --fix",
      "pnpm --filter @zapengine/account-engine exec prettier --write"
    ],
    "apps/alpha-etl/**/*.{ts,js}": [
      "pnpm --filter @zapengine/alpha-etl exec eslint --fix",
      "pnpm --filter @zapengine/alpha-etl exec prettier --write"
    ],
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/frontend exec eslint --fix",
      "pnpm --filter @zapengine/frontend exec prettier --write"
    ],
    "apps/landing-page/**/*.{ts,tsx}": [
      "pnpm --filter @zapengine/landing-page exec eslint --fix",
      "pnpm --filter @zapengine/landing-page exec prettier --write"
    ],
    "packages/**/*.{js,mjs,cjs,ts,tsx,json,md}": [
      "pnpm --filter @zapengine/eslint-config exec prettier --write"
    ],
    "apps/analytics-engine/**/*.py": [
      "pnpm --filter @zapengine/analytics-engine exec uv run ruff check --fix"
    ]
  }
}
