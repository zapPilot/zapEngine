{
  "name": "@zapengine/app-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./services/suggestion": {
      "types": "./dist/services/suggestion/index.d.ts",
      "import": "./dist/services/suggestion/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./regime": {
      "types": "./dist/regime/index.d.ts",
      "import": "./dist/regime/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./hooks/queries": {
      "types": "./dist/hooks/queries/index.d.ts",
      "import": "./dist/hooks/queries/index.js"
    },
    "./hooks/queries/strategyAdmin": {
      "types": "./dist/hooks/queries/strategyAdmin/index.d.ts",
      "import": "./dist/hooks/queries/strategyAdmin/index.js"
    },
    "./hooks/analytics": {
      "types": "./dist/hooks/analytics/index.d.ts",
      "import": "./dist/hooks/analytics/index.js"
    },
    "./hooks/bundle": {
      "types": "./dist/hooks/bundle/index.d.ts",
      "import": "./dist/hooks/bundle/index.js"
    },
    "./hooks/wallet": {
      "types": "./dist/hooks/wallet/index.d.ts",
      "import": "./dist/hooks/wallet/index.js"
    },
    "./hooks/mutations": {
      "types": "./dist/hooks/mutations/index.d.ts",
      "import": "./dist/hooks/mutations/index.js"
    },
    "./hooks/utils": {
      "types": "./dist/hooks/utils/index.d.ts",
      "import": "./dist/hooks/utils/index.js"
    },
    "./lib/http": {
      "types": "./dist/lib/http/index.d.ts",
      "import": "./dist/lib/http/index.js"
    },
    "./lib/state": {
      "types": "./dist/lib/state/index.d.ts",
      "import": "./dist/lib/state/index.js"
    },
    "./lib/env": {
      "types": "./dist/lib/env/index.d.ts",
      "import": "./dist/lib/env/index.js"
    },
    "./lib/errors": {
      "types": "./dist/lib/errors/index.d.ts",
      "import": "./dist/lib/errors/index.js"
    },
    "./lib/wallet": {
      "types": "./dist/lib/wallet/index.d.ts",
      "import": "./dist/lib/wallet/index.js"
    },
    "./lib/domain": {
      "types": "./dist/lib/domain/index.d.ts",
      "import": "./dist/lib/domain/index.js"
    },
    "./lib/validation": {
      "types": "./dist/lib/validation/index.d.ts",
      "import": "./dist/lib/validation/index.js"
    },
    "./lib/portfolio": {
      "types": "./dist/lib/portfolio/index.d.ts",
      "import": "./dist/lib/portfolio/index.js"
    },
    "./lib/analytics": {
      "types": "./dist/lib/analytics/index.d.ts",
      "import": "./dist/lib/analytics/index.js"
    },
    "./lib/bundle": {
      "types": "./dist/lib/bundle/index.d.ts",
      "import": "./dist/lib/bundle/index.js"
    },
    "./lib/ui": {
      "types": "./dist/lib/ui/index.d.ts",
      "import": "./dist/lib/ui/index.js"
    },
    "./providers/walletContext": {
      "types": "./dist/providers/walletContext.d.ts",
      "import": "./dist/providers/walletContext.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "deadcode": "knip",
    "deadcode:fix": "knip --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "catalog:",
    "@zapengine/design-tokens": "workspace:*",
    "@zapengine/intent-engine": "workspace:*",
    "@zapengine/types": "workspace:*",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.19.1",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@privy-io/react-auth": "^3.29.2",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-devtools": "^5.85.3",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependenciesMeta": {
    "@privy-io/react-auth": {
      "optional": true
    },
    "@tanstack/react-query-devtools": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@zapengine/eslint-config": "workspace:*",
    "jsdom": "catalog:",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "tsc-alias": "^1.8.16",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
