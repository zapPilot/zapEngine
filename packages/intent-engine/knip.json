{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "examples/basic-usage.ts"
  ],
  "project": [
    "src/**/*.ts",
    "test/**/*.ts",
    "examples/**/*.ts"
  ],
  "ignoreDependencies": [
    "@zapengine/eslint-config"
  ],
  "ignoreExportsUsedInFile": true,
  "eslint": {
    "config": [
      "eslint.config.mjs"
    ]
  },
  "vitest": {
    "entry": [
      "test/**/*.{test,spec}.ts"
    ]
  }
}
