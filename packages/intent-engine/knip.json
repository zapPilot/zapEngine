{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/index.ts",
    "src/types/index.ts",
    "src/protocols/morpho/index.ts",
    "examples/basic-usage.ts"
  ],
  "project": [
    "src/**/*.ts",
    "test/**/*.ts",
    "examples/**/*.ts"
