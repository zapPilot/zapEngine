{
  "name": "@zapengine/intent-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./morpho": {
      "types": "./dist/protocols/morpho/index.d.ts",
      "import": "./dist/protocols/morpho/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "lint": "eslint src test examples --ext .ts",
    "lint:fix": "eslint src test examples --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "deadcode": "knip",
    "dup:check": "jscpd src --config .jscpd.json",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lifi/sdk": "^3.4.0",
    "@zapengine/types": "workspace:*",
    "viem": "catalog:",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "jscpd": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
