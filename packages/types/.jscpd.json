{
  "ignore": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/test/**",
    "**/tests/**",
    "dist/**",
    "node_modules/**",
    ".turbo/**",
    "coverage/**"
  ],
  "ignorePattern": [
    "import\\s.*from\\s.*",
    "import\\s*\\{[\\s\\S]*?\\}\\s*from\\s*'[^']*'"
  ],
  "format": ["typescript"]
}
