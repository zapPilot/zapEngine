{
  "name": "@zapengine/types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./etl": {
      "types": "./dist/etl/index.d.ts",
      "import": "./dist/etl/index.js",
      "require": "./dist/etl/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.js"
    },
    "./strategy": {
      "types": "./dist/strategy/index.d.ts",
      "import": "./dist/strategy/index.js",
      "require": "./dist/strategy/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deadcode": "knip",
    "deadcode:fix": "knip --fix",
    "dup:check": "node ../../scripts/lint/run-jscpd.mjs src"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@zapengine/eslint-config": "workspace:*",
    "@zapengine/knip-config": "workspace:*",
    "@zapengine/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x"
  }
}
