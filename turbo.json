{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".nvmrc",
    ".env.example",
    ".jscpd.json",
    "pnpm-lock.yaml",
    "package.json",
    "pnpm-workspace.yaml"
  ],
  "globalEnv": ["NODE_ENV", "CI"],
  "futureFlags": {
    "longerSignatureKey": true
  },
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "out/**",
        "build/**",
        "src/generated/**"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md", "!src/generated/**"],
      "env": ["EXPO_PUBLIC_*", "NEXT_PUBLIC_*", "VITE_*"]
    },
    "build:web": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md"],
      "env": ["EXPO_PUBLIC_*", "VITE_*"]
    },
    "codegen": {
      "inputs": ["$TURBO_DEFAULT$", "tokens.json", "!src/generated/**"],
      "outputs": ["dist/**", "lib/design_tokens.dart", "src/generated/**"]
    },
    "codegen:css": {
      "inputs": ["$TURBO_DEFAULT$", "tokens.json"],
      "outputs": ["dist/css/variables.css"]
    },
    "codegen:flutter": {
      "inputs": ["$TURBO_DEFAULT$", "tokens.json"],
      "outputs": ["dist/flutter/design_tokens.dart", "lib/design_tokens.dart"]
    },
    "codegen:ts": {
      "inputs": ["$TURBO_DEFAULT$", "tokens.json", "!src/generated/**"],
      "outputs": ["src/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "dev:web": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["format"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md"],
      "passThroughEnv": [
        "DATABASE_READ_ONLY",
        "DATABASE_READ_ONLY_URL",
        "TEST_DATABASE_URL",
        "DATABASE_INTEGRATION_URL"
      ],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md"],
      "passThroughEnv": [
        "DATABASE_READ_ONLY",
        "DATABASE_READ_ONLY_URL",
        "TEST_DATABASE_URL",
        "DATABASE_INTEGRATION_URL"
      ],
      "outputs": ["coverage/**", "htmlcov/**"]
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!**/*.md"],
      "passThroughEnv": [
        "DATABASE_READ_ONLY",
        "DATABASE_READ_ONLY_URL",
        "TEST_DATABASE_URL",
        "DATABASE_INTEGRATION_URL"
      ],
      "outputs": []
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "deadcode": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "deadcode:fix": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "dup:check": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "security:audit": {
      "outputs": [],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "test:e2e:safe": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "sql:audit": {
      "outputs": [],
      "cache": true
    },
    "service-reachability": {
      "outputs": [],
      "cache": true
    },
    "pylint:duplicate-check": {
      "outputs": [],
      "cache": true
    }
  }
}
